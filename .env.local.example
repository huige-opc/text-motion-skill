# 复制本文件为 .env.local 并填入你自己的密钥
# .env.local 不会被 git 提交

# 百度语音合成（用于 generate-full-audio.mjs / generate-tts-audio.mjs）
# 申请地址：https://console.bce.baidu.com/ai/#/ai/speech/app/list
BAIDU_API_KEY=your_baidu_api_key_here
BAIDU_SECRET=your_baidu_secret_here

# pixazo VoxCPM（用于 test-tts.mjs，可选）
VOXCPM_API_KEY=your_voxcpm_key_here
